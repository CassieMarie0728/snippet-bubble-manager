# .codedocs for snippet-bubble-manager-main

DOXYFILE =
TAGLINKS =

PROJECT_NAME = Snippet Bubble Manager
PROJECT_BRIEF = Vite React TypeScript app with Node backend for managing reusable snippets and templates.
PROJECT_NUMBER = 1.0.0
OUTPUT_LANGUAGE = English

ALLOW_UNICODE_NAMES = YES
ALPHABETICAL_INDEX = YES
AUTOLINK_SUPPORT = YES
BRIEF_MEMBER_DESC = YES
CASE_SENSE_NAMES = YES
CLASS_DIAGRAMS = YES
CLASS_GRAPH = YES
COLLABORATION_GRAPH = YES
DIRECTORY_GRAPH = YES
DISABLE_INDEX = NO
DOT_FONTSIZE = 10
DOT_GRAPH_MAX_NODES = 50
DOT_IMAGE_FORMAT = svg
DOT_TRANSPARENT = YES
DOXYFILE_ENCODING = UTF-8
ENABLE_PREPROCESSING = YES

EXCLUDE = node_modules dist build .git .github docs/images pulls .env .env.example package-lock.json
EXCLUDE_PATTERNS = */node_modules/* */dist/* */build/* */.git/* */.github/*

EXTENSION_MAPPING = ts=C++ tsx=C++ js=Javascript jsx=Javascript md=Markdown json=JSON
EXTRACT_ALL = YES
EXTRACT_ANON_NSPACES = YES
EXTRACT_LOCAL_CLASSES = YES
EXTRACT_LOCAL_METHODS = YES
EXTRACT_PACKAGE = YES
EXTRACT_PRIVATE = NO
EXTRACT_STATIC = YES

FILE_PATTERNS = *.ts *.tsx *.js *.jsx *.md
FULL_PATH_NAMES = NO

GENERATE_BUGLIST = YES
GENERATE_DEPRECATEDLIST = YES
GENERATE_LEGEND = YES
GENERATE_TESTLIST = YES
GENERATE_TODOLIST = YES
GENERATE_TREEVIEW = YES
GRAPHICAL_HIERARCHY = YES
GROUP_GRAPHS = YES
GROUP_NESTED_COMPOUNDS = YES

HIDE_COMPOUND_REFERENCE = NO
HIDE_IN_BODY_DOCS = NO
HIDE_SCOPE_NAMES = NO
HIDE_UNDOC_CLASSES = NO
HIDE_UNDOC_MEMBERS = NO
HIDE_UNDOC_RELATIONS = YES

HTML_COLORSTYLE_GAMMA = 80
HTML_COLORSTYLE_HUE = 220
HTML_COLORSTYLE_SAT = 100
HTML_DYNAMIC_SECTIONS = YES
HTML_INDEX_NUM_ENTRIES = 100
HTML_TIMESTAMP = YES

INCLUDED_BY_GRAPH = YES
INCLUDE_GRAPH = YES
INHERIT_DOCS = YES
INLINE_INFO = YES
INLINE_SIMPLE_STRUCTS = YES
INLINE_SOURCES = NO

INPUT = README.md API.md ARCHITECTURE.md CONTRIBUTING.md src backend
INPUT_ENCODING = UTF-8
INTERACTIVE_SVG = YES
INTERNAL_DOCS = NO
JAVADOC_AUTOBRIEF = YES
MARKDOWN_SUPPORT = YES
MAX_DOT_GRAPH_DEPTH = 2
MULTILINE_CPP_IS_BRIEF = YES

QT_AUTOBRIEF = NO
RECURSIVE = YES
REFERENCED_BY_RELATION = YES
REFERENCES_LINK_SOURCE = YES
REFERENCES_RELATION = YES
REPEAT_BRIEF = NO
SEARCHENGINE = YES
SEARCH_INCLUDES = YES
SEPARATE_MEMBER_PAGES = NO
SHORT_NAMES = NO

SHOW_FILES = YES
SHOW_INCLUDE_FILES = NO
SHOW_NAMESPACES = YES
SHOW_USED_FILES = YES
SKIP_FUNCTION_MACROS = YES
SORT_BRIEF_DOCS = YES
SORT_GROUP_NAMES = YES
SORT_MEMBERS_CTORS_1ST = YES
SORT_MEMBER_DOCS = YES

SOURCE_BROWSER = YES
SOURCE_TOOLTIPS = YES
STRICT_PROTO_MATCHING = NO
STRIP_CODE_COMMENTS = NO
STRIP_FROM_PATH = .
SUBGROUPING = YES
TAB_SIZE = 2
TEMPLATE_RELATIONS = YES
TREEVIEW_WIDTH = 250
TYPEDEF_HIDES_STRUCT = NO
UML_LIMIT_NUM_FIELDS = 10
UML_LOOK = YES

USE_MDFILE_AS_MAINPAGE = README.md
VERBATIM_HEADERS = YES
